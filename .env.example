/*
 * LifeFlow - Blood Donor Management System
 * Configuration for environment variables
 * 
 * IMPORTANT: Rename this file to .env in production
 * Add .env to .gitignore to keep credentials secure
 */

// Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=lifeflow

// Site Configuration
SITE_NAME=LifeFlow
SITE_URL=http://localhost/lifeflow
SITE_EMAIL=contact@lifeflow.com

// Security
SESSION_TIMEOUT=3600
SESSION_NAME=lifeflow_session

// API Keys (for future integrations)
GOOGLE_MAPS_API_KEY=
TWILIO_API_KEY=
SENDGRID_API_KEY=

// Feature Flags
ENABLE_GEOLOCATION=false
ENABLE_SMS_NOTIFICATIONS=false
ENABLE_EMAIL_NOTIFICATIONS=false

// Debug Mode (Set to false in production)
DEBUG_MODE=true
DISPLAY_ERRORS=true

// Timezone
TIMEZONE=Asia/Kolkata

// Language Settings
DEFAULT_LANGUAGE=en
AVAILABLE_LANGUAGES=en,gu,hi

// Upload Settings
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf

// Pagination
DONORS_PER_PAGE=12

// Cache Settings
ENABLE_CACHE=false
CACHE_DURATION=3600

// Rate Limiting
ENABLE_RATE_LIMIT=false
MAX_REQUESTS_PER_MINUTE=60

// Logging
ENABLE_LOGGING=true
LOG_FILE_PATH=logs/app.log
LOG_LEVEL=info
